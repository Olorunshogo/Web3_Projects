{
  "name": "@starknetfoundation/starknet-agentic-autonomous-transfer-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Composable autonomous transfer agent: balance fetch, conditional transfer, alerts, hooks, and receipts via starknet-agentic MCP.",
  "type": "module",
  "scripts": {
    "run": "npx tsx src/run.ts",
    "run:dry": "npx tsx src/run.ts --dry-run",
    "run:strk-sepolia": "npx tsx src/run.ts --profile strk-sepolia",
    "run:strk-sepolia:dry": "npx tsx src/run.ts --profile strk-sepolia --dry-run",
    "run:shogo": "npx tsx src/run.ts --profile strk-sepolia",
    "run:shogo:dry": "npx tsx src/run.ts --profile strk-sepolia --dry-run",
    "run:mtk-spending-token": "npx tsx src/run.ts --profile mtk-spending-token",
    "run:mtk-spending-token:dry": "npx tsx src/run.ts --profile mtk-spending-token --dry-run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --test --import tsx test/*.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
