# Starknet MCP (mirrors starknet-agentic)
STARKNET_RPC_URL=https://starknet-sepolia.public.blastapi.io/rpc/v0_9
STARKNET_ACCOUNT_ADDRESS=0x...
STARKNET_PRIVATE_KEY=0x...
STARKNET_SIGNER_MODE=direct

# Optional: off-chain spending policy (JSON string or path)
# STARKNET_MCP_POLICY={"transfer":{"maxAmountPerCall":"10","allowedRecipients":["0x..."]}}
# STARKNET_MCP_POLICY_PATH=

# Optional: gasless transfers
# AVNU_PAYMASTER_API_KEY=
# AVNU_PAYMASTER_FEE_MODE=sponsored

# Agent paths (defaults resolve automatically)
# AGENT_CONFIG_PATH=./agent.config.json
# MCP_ENTRY_PATH=../../packages/starknet-mcp-server/dist/index.js

# SpendingToken (MTK profile)
# SPENDING_TOKEN_ADDRESS=0x...
